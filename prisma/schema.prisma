// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SpaceRole {
  owner
  member
}

enum InvitationStatus {
  pending
  accepted
  rejected
  cancelled
  expired
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskStatus {
  pending
  completed
}

enum TaskEventType {
  task_created
  task_updated
  task_assigned
  task_unassigned
  task_completed
  task_reopened
  task_deleted
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  googleSub  String?   @unique
  publicCode String    @unique
  name       String
  imageUrl   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  spacesCreated          Space[]         @relation("SpaceCreatedBy")
  spacesDeleted          Space[]         @relation("SpaceDeletedBy")
  spaceMemberships       SpaceMember[]
  invitationsSent        Invitation[]    @relation("InvitationInvitedBy")
  invitationsReceived    Invitation[]    @relation("InvitationInvitedUser")
  tasksCreated           Task[]          @relation("TaskCreatedBy")
  tasksUpdated           Task[]          @relation("TaskUpdatedBy")
  tasksDeleted           Task[]          @relation("TaskDeletedBy")
  tasksCompleted         Task[]          @relation("TaskCompletedBy")
  taskAssignees          TaskAssignee[]   @relation("TaskAssigneeUser")
  taskAssignmentsMade    TaskAssignee[]   @relation("TaskAssigneeAssignedBy")
  taskEvents             TaskEvent[]      @relation("TaskEventActor")
}

model Space {
  id              String    @id @default(uuid())
  name            String
  createdByUserId String
  deletedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  createdByUser User           @relation("SpaceCreatedBy", fields: [createdByUserId], references: [id])
  deletedByUser User?          @relation("SpaceDeletedBy", fields: [deletedByUserId], references: [id])
  members       SpaceMember[]
  invitations   Invitation[]
  tasks         Task[]

  @@index([createdByUserId])
  @@index([deletedByUserId])
}

model SpaceMember {
  id        String     @id @default(uuid())
  spaceId   String
  userId    String
  role      SpaceRole
  joinedAt  DateTime   @default(now())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  space Space @relation(fields: [spaceId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([spaceId, userId])
  @@index([userId])
  @@index([spaceId])
}

model Invitation {
  id              String           @id @default(uuid())
  spaceId         String
  invitedByUserId String
  invitedUserId   String
  status          InvitationStatus @default(pending)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  respondedAt     DateTime?
  expiresAt       DateTime?
  deletedAt       DateTime?

  space       Space @relation(fields: [spaceId], references: [id])
  invitedBy   User  @relation("InvitationInvitedBy", fields: [invitedByUserId], references: [id])
  invitedUser User  @relation("InvitationInvitedUser", fields: [invitedUserId], references: [id])

  @@index([spaceId, status])
  @@index([invitedUserId])
  @@index([invitedByUserId])
  @@index([status])
}

model Task {
  id                String       @id @default(uuid())
  spaceId           String
  title             String
  description       String?
  priority          TaskPriority @default(medium)
  photoUrl          String?
  dueDate           DateTime?
  status            TaskStatus   @default(pending)
  createdByUserId   String
  updatedByUserId   String
  deletedByUserId   String?
  completedByUserId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  completedAt       DateTime?

  space           Space @relation(fields: [spaceId], references: [id])
  createdByUser   User  @relation("TaskCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser   User  @relation("TaskUpdatedBy", fields: [updatedByUserId], references: [id])
  deletedByUser   User? @relation("TaskDeletedBy", fields: [deletedByUserId], references: [id])
  completedByUser User? @relation("TaskCompletedBy", fields: [completedByUserId], references: [id])
  assignees       TaskAssignee[]
  events          TaskEvent[]

  @@index([spaceId])
  @@index([spaceId, status])
  @@index([dueDate])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model TaskAssignee {
  id               String    @id @default(uuid())
  taskId           String
  userId           String
  assignedByUserId String
  createdAt        DateTime  @default(now())
  assignedAt       DateTime  @default(now())
  unassignedAt     DateTime?

  task       Task @relation(fields: [taskId], references: [id])
  user       User @relation("TaskAssigneeUser", fields: [userId], references: [id])
  assignedBy User @relation("TaskAssigneeAssignedBy", fields: [assignedByUserId], references: [id])

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskEvent {
  id          String        @id @default(uuid())
  taskId      String
  actorUserId String
  type        TaskEventType
  payload     Json?
  createdAt   DateTime      @default(now())

  task  Task @relation(fields: [taskId], references: [id])
  actor User @relation("TaskEventActor", fields: [actorUserId], references: [id])

  @@index([taskId, createdAt])
}
