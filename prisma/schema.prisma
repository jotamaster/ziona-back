// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum HomeRole {
  owner
  member
}

enum InvitationStatus {
  pending
  accepted
  rejected
  cancelled
  expired
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskStatus {
  pending
  completed
}

enum TaskEventType {
  task_created
  task_updated
  task_assigned
  task_unassigned
  task_completed
  task_reopened
  task_deleted
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  googleSub  String?   @unique
  publicCode String    @unique
  name       String
  imageUrl   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  homesCreated          Home[]         @relation("HomeCreatedBy")
  homesDeleted          Home[]         @relation("HomeDeletedBy")
  homeMemberships       HomeMember[]
  invitationsSent       Invitation[]   @relation("InvitationInvitedBy")
  invitationsReceived   Invitation[]   @relation("InvitationInvitedUser")
  tasksCreated          Task[]         @relation("TaskCreatedBy")
  tasksUpdated          Task[]         @relation("TaskUpdatedBy")
  tasksDeleted          Task[]         @relation("TaskDeletedBy")
  tasksCompleted        Task[]         @relation("TaskCompletedBy")
  taskAssignees         TaskAssignee[] @relation("TaskAssigneeUser")
  taskAssignmentsMade   TaskAssignee[] @relation("TaskAssigneeAssignedBy")
  taskEvents            TaskEvent[]    @relation("TaskEventActor")
}

model Home {
  id                String    @id @default(uuid())
  name              String
  createdByUserId   String
  deletedByUserId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  createdByUser User           @relation("HomeCreatedBy", fields: [createdByUserId], references: [id])
  deletedByUser User?          @relation("HomeDeletedBy", fields: [deletedByUserId], references: [id])
  members       HomeMember[]
  invitations   Invitation[]
  tasks         Task[]

  @@index([createdByUserId])
  @@index([deletedByUserId])
}

model HomeMember {
  id        String    @id @default(uuid())
  homeId    String
  userId    String
  role      HomeRole
  joinedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  home Home @relation(fields: [homeId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([homeId, userId])
  @@index([userId])
  @@index([homeId])
}

model Invitation {
  id               String           @id @default(uuid())
  homeId           String
  invitedByUserId  String
  invitedUserId    String
  status           InvitationStatus @default(pending)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  respondedAt      DateTime?
  expiresAt        DateTime?
  deletedAt        DateTime?

  home        Home @relation(fields: [homeId], references: [id])
  invitedBy   User @relation("InvitationInvitedBy", fields: [invitedByUserId], references: [id])
  invitedUser User @relation("InvitationInvitedUser", fields: [invitedUserId], references: [id])

  @@index([homeId, status])
  @@index([invitedUserId])
  @@index([invitedByUserId])
  @@index([status])
}

model Task {
  id                String        @id @default(uuid())
  homeId            String
  title             String
  description       String?
  priority          TaskPriority @default(medium)
  photoUrl          String?
  dueDate           DateTime?
  status            TaskStatus   @default(pending)
  createdByUserId   String
  updatedByUserId   String
  deletedByUserId   String?
  completedByUserId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  completedAt       DateTime?

  home Home @relation(fields: [homeId], references: [id])
  createdByUser User @relation("TaskCreatedBy", fields: [createdByUserId], references: [id])
  updatedByUser User @relation("TaskUpdatedBy", fields: [updatedByUserId], references: [id])
  deletedByUser User? @relation("TaskDeletedBy", fields: [deletedByUserId], references: [id])
  completedByUser User? @relation("TaskCompletedBy", fields: [completedByUserId], references: [id])
  assignees       TaskAssignee[]
  events          TaskEvent[]

  @@index([homeId])
  @@index([homeId, status])
  @@index([dueDate])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model TaskAssignee {
  id               String    @id @default(uuid())
  taskId           String
  userId           String
  assignedByUserId String
  createdAt        DateTime  @default(now())
  assignedAt       DateTime  @default(now())
  unassignedAt     DateTime?

  task       Task @relation(fields: [taskId], references: [id])
  user       User @relation("TaskAssigneeUser", fields: [userId], references: [id])
  assignedBy User @relation("TaskAssigneeAssignedBy", fields: [assignedByUserId], references: [id])

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskEvent {
  id          String        @id @default(uuid())
  taskId      String
  actorUserId String
  type        TaskEventType
  payload     Json?
  createdAt   DateTime      @default(now())

  task  Task @relation(fields: [taskId], references: [id])
  actor User @relation("TaskEventActor", fields: [actorUserId], references: [id])

  @@index([taskId, createdAt])
}
